# Config A — Qwen2.5-VL-7B-Instruct (Unquantized, fp16)
# Lighter model, faster inference, good quality vision
VLLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VLLM_DTYPE=bfloat16
VLLM_QUANTIZATION=
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_MAX_MODEL_LEN=8192
VLLM_LIMIT_MM_PER_PROMPT=image=4,video=2
VLLM_EXTRA_ARGS=
