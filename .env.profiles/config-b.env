# Config B — Qwen2.5-VL-32B-Instruct-AWQ (4-bit Quantized)
# Maximum quality vision, larger model, AWQ quantization
VLLM_MODEL=Qwen/Qwen2.5-VL-32B-Instruct-AWQ
VLLM_DTYPE=float16
VLLM_QUANTIZATION=awq
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_MODEL_LEN=8192
VLLM_LIMIT_MM_PER_PROMPT=image=4,video=2
VLLM_EXTRA_ARGS=
