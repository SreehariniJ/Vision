# ============================================================
# Vision — Environment Configuration
# Copy this file to .env and fill in values
# ============================================================

# --- Model Profile ---
# A = Qwen2.5-VL-7B-Instruct (unquantized, fp16)
# B = Qwen2.5-VL-32B-Instruct-AWQ (4-bit quantized)
VISION_MODEL_PROFILE=A

# --- General ---
PROJECT_NAME=vision
DOMAIN=localhost
TZ=Asia/Kolkata

# --- FastAPI Backend ---
BACKEND_PORT=8000
BACKEND_SECRET_KEY=change-me-to-a-random-secret-key
BACKEND_DEBUG=false
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:3000"]

# --- vLLM Model Serving ---
VLLM_PORT=8001
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_MAX_MODEL_LEN=8192
# Model paths (set after running download-models.sh)
VLLM_MODEL_PATH_A=Qwen/Qwen2.5-VL-7B-Instruct
VLLM_MODEL_PATH_B=Qwen/Qwen2.5-VL-32B-Instruct-AWQ
# HuggingFace cache directory (where models are stored)
HF_HOME=/root/.cache/huggingface
# The host directory where models are downloaded (default: ~/.cache/huggingface)
# If your guide downloaded models to a custom location, change this path!
HF_HOME_HOST=~/.cache/huggingface

# --- Embedding Service (BGE-M3) ---
EMBEDDING_PORT=8003
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32

# --- Reranker Service (BGE-Reranker-v2-M3) ---
RERANKER_PORT=8004
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cuda
RERANKER_TOP_K=5

# --- Docling Service ---
DOCLING_PORT=8005

# --- PaddleOCR Service ---
OCR_PORT=8006
OCR_LANG=en

# --- MySQL 8 ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=vision
MYSQL_USER=vision
MYSQL_PASSWORD=change-me-db-password

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=vision_chunks

# --- Neo4j ---
NEO4J_HOST=neo4j
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j-password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password

# --- MinIO (S3-compatible Object Storage) ---
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET=vision-documents

# --- OpenWebUI ---
OPENWEBUI_PORT=3000
OPENWEBUI_SECRET_KEY=change-me-openwebui-secret
# Points to our FastAPI backend (OpenAI-compatible)
OPENAI_API_BASE_URL=http://backend:8000/v1
OPENAI_API_KEY=vision-internal-key

# --- Nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Grafana ---
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# --- Celery ---
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/1
